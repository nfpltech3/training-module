# Trainings Backend environment example
#
# This file shows both development and production-style values.
# Keep only one value per variable in your real .env.

# -----------------------------------------------------------------------------
# App secrets
# -----------------------------------------------------------------------------

SECRET_KEY=replace-with-a-long-random-jwt-secret

# Cookie settings used by app/auth.py
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Production example:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Preferred: single DATABASE_URL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nagarkot_training

# Dokploy-style URLs like postgres://... are also supported.

# Optional split fields fallback if your platform does not provide DATABASE_URL:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nagarkot_training
DB_USER=postgres
DB_PASSWORD=postgres

# Production example:
# DATABASE_URL=postgres://<user>:<password>@<host>:5432/nagarkot_training
# DB_HOST=<postgres-host>
# DB_PORT=5432
# DB_NAME=nagarkot_training
# DB_USER=<postgres-user>
# DB_PASSWORD=<postgres-password>

# -----------------------------------------------------------------------------
# OS connection
# -----------------------------------------------------------------------------

# Development:
OS_BACKEND_URL=http://localhost:3001
INTERNAL_API_KEY=replace-with-shared-internal-api-key

# Production example:
# If OS backend is publicly exposed under /api, include /api here.
# OS_BACKEND_URL=https://os.int.nagarkot.co.in/api
# INTERNAL_API_KEY=replace-with-shared-internal-api-key

# OS public key used to verify SSO tokens from OS
OS_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<public-key>\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Development:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8000

# Production example:
# Do not leave spaces after commas.
# ALLOWED_ORIGINS=https://os.int.nagarkot.co.in,https://trainings.int.nagarkot.co.in
