# Trainings Frontend environment example
#
# Keep only one value per variable in your real .env.

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Direct backend origin for local dev.
VITE_API_URL=http://localhost:8000
VITE_OS_PORTAL_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Production example
# -----------------------------------------------------------------------------

# Option A: same-domain proxy setup
# Use this only if your production web server proxies /api to the FastAPI backend.
# VITE_API_URL=/api
#
# Option B: public backend URL
# Use this if the browser must call the backend directly.
# VITE_API_URL=https://trainings.int.nagarkot.co.in/api
#
# OS portal URL used for links back to the hub.
# VITE_OS_PORTAL_URL=https://os.int.nagarkot.co.in

# After changing VITE_* values, rebuild the frontend.
